{
  "rules": [
    {
      "effect": "Allow",
      "matches": {
        "targets": [],
        "verbs": [ { "type": "Crud", "value": { "kind": "Read" } } ],
        "resources": ["repos/octocat/*/**"],
        "conditions": []
      }
    },
    {
      "effect": "Allow",
      "matches": {
        "targets": [],
        "verbs": [ { "type": "Crud", "value": { "kind": "Create" } } ],
        "resources": ["repos/octocat/*/pulls"],
        "conditions": [
          { "type": "Equals", "value": { "field": "base", "value": "develop" } }
        ]
      }
    }
  ]
}
